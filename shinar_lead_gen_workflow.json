    {
      "parameters": {
        "respondWith": "html",
        "html": "<!DOCTYPE html><html><head><meta charset='UTF-8'/><style>body{background:#0B0C0E;font-family:sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;}div{text-align:center;padding:40px;}h2{color:#00E5A0;font-size:24px;margin-bottom:12px;}p{color:#9A9B99;font-size:15px;line-height:1.7;}</style></head><body><div><h2>Message received.</h2><p>Thanks for reaching out. I'll get back to you within 24 hours.<br/>Check your inbox for a confirmation.</p></div></body></html>",
        "options": {}
