{
  "name": "Lead Generation — Portfolio Contact Form",
  "nodes": [
    {
      "parameters": {
        "formTitle": "Get in Touch",
        "formDescription": "Tell me about your project or opportunity. I'll respond within 24 hours.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Full Name",
              "fieldType": "text",
              "requiredField": true,
              "placeholder": "Your full name"
            },
            {
              "fieldLabel": "Email Address",
              "fieldType": "email",
              "requiredField": true,
              "placeholder": "you@company.com"
            },
            {
              "fieldLabel": "Company / Organisation",
              "fieldType": "text",
              "requiredField": false,
              "placeholder": "Optional"
            },
            {
              "fieldLabel": "I'm interested in",
              "fieldType": "dropdown",
              "requiredField": true,
              "fieldOptions": {
                "values": [
                  { "option": "Hiring / Graduate Role" },
                  { "option": "Freelance Automation Project" },
                  { "option": "Consulting / Workflow Audit" },
                  { "option": "Collaboration / Open Source" },
                  { "option": "Something else" }
                ]
              }
            },
            {
              "fieldLabel": "Budget Range (if applicable)",
              "fieldType": "dropdown",
              "requiredField": false,
              "fieldOptions": {
                "values": [
                  { "option": "Under $500" },
                  { "option": "$500 – $2,000" },
                  { "option": "$2,000 – $5,000" },
                  { "option": "$5,000+" },
                  { "option": "Not applicable" }
                ]
              }
            },
            {
              "fieldLabel": "Tell me more",
              "fieldType": "textarea",
              "requiredField": true,
              "placeholder": "Describe what you're building, the problem you want solved, or the role you're filling…"
            }
          ]
        },
        "responseMode": "lastNode",
        "options": {}
