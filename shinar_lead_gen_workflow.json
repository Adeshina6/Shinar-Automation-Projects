    },
    {
      "parameters": {
        "sendTo": "={{ $json.email }}",
        "subject": "Got your message, {{ $json.name }} — I'll be in touch",
        "emailType": "html",
        "message": "=<div style=\"font-family:sans-serif;max-width:520px;margin:0 auto;\">\n  <div style=\"background:#0d1117;padding:20px 24px;border-radius:8px 8px 0 0;\">\n    <p style=\"color:#00E5A0;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;margin:0;\">Shinar Automation</p>\n    <h2 style=\"color:#F0F0EE;margin:8px 0 0;font-size:20px;\">Thanks, {{ $json.name }}.</h2>\n  </div>\n  <div style=\"background:#14161A;padding:20px 24px;border-radius:0 0 8px 8px;border:1px solid rgba(255,255,255,0.07);border-top:none;\">\n    <p style=\"color:#9A9B99;font-size:14px;line-height:1.8;\">Your message came through. I've noted your interest in <strong style=\"color:#F0F0EE;\">{{ $json.interest }}</strong> and will get back to you within <strong style=\"color:#F0F0EE;\">24 hours</strong>.</p>\n    <p style=\"color:#9A9B99;font-size:14px;line-height:1.8;\">In the meantime, feel free to explore my projects on GitHub or connect on LinkedIn.</p>\n    <div style=\"margin-top:20px;display:flex;gap:10px;\">\n      <a href=\"https://github.com/Adeshina6/Shinar-Automation-Projects\" style=\"display:inline-block;background:#00E5A0;color:#0B0C0E;padding:10px 18px;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;\">GitHub ↗</a>\n      <a href=\"https://linkedin.com/in/muhammed-adetunji-abiodun\" style=\"display:inline-block;background:transparent;color:#00E5A0;padding:10px 18px;border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;border:1px solid rgba(0,229,160,0.4);\">LinkedIn ↗</a>\n    </div>\n  </div>\n  <p style=\"color:#5C5D5B;font-size:11px;text-align:center;margin-top:12px;\">Muhammed Adetunji · Automation & AI Workflow Engineer · Nigeria (Remote-ready)</p>\n</div>",
        "options": {}
      },
      "id": "node-autorespond",
      "name": "Auto-respond to Lead (Gmail)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [680, 420],
