      "id": "node-form-trigger",
      "name": "On Form Submission",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "shinar-lead-form-001"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst lead = {\n  name:        data['Full Name'] || '',\n  email:       data['Email Address'] || '',\n  company:     data['Company / Organisation'] || 'Not provided',\n  interest:    data[\"I'm interested in\"] || '',\n  budget:      data['Budget Range (if applicable)'] || 'Not provided',\n  message:     data['Tell me more'] || '',\n  submitted_at: new Date().toISOString(),\n  source:      'Portfolio Contact Form'\n};\n\nreturn [{ json: lead }];"
      },
      "id": "node-format",
      "name": "Format Lead Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "sendTo": "adetunjimuhammed26@gmail.com",
        "subject": "=New Lead: {{ $json.interest }} — {{ $json.name }}",
        "emailType": "html",
        "message": "=<div style=\"font-family:sans-serif;max-width:560px;margin:0 auto;\">\n  <div style=\"background:#0d1117;padding:20px 24px;border-radius:8px 8px 0 0;\">\n    <p style=\"color:#00E5A0;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;margin:0;\">Shinar Automation · New Lead</p>\n    <h2 style=\"color:#F0F0EE;margin:8px 0 0;font-size:20px;\">{{ $json.name }}</h2>\n    <p style=\"color:#9A9B99;margin:4px 0 0;font-size:14px;\">{{ $json.email }}{% if $json.company != 'Not provided' %} · {{ $json.company }}{% endif %}</p>\n  </div>\n  <div style=\"background:#14161A;padding:20px 24px;border-radius:0 0 8px 8px;border:1px solid rgba(255,255,255,0.07);border-top:none;\">\n    <table style=\"width:100%;font-size:14px;border-collapse:collapse;\">\n      <tr><td style=\"color:#5C5D5B;padding:6px 0;width:140px;\">Interested in</td><td style=\"color:#F0F0EE;\">{{ $json.interest }}</td></tr>\n      <tr><td style=\"color:#5C5D5B;padding:6px 0;\">Budget</td><td style=\"color:#F0F0EE;\">{{ $json.budget }}</td></tr>\n      <tr><td style=\"color:#5C5D5B;padding:6px 0;\">Submitted</td><td style=\"color:#F0F0EE;\">{{ $json.submitted_at }}</td></tr>\n    </table>\n    <div style=\"margin-top:16px;padding:14px;background:#0B0C0E;border-left:3px solid #00E5A0;border-radius:0 4px 4px 0;\">\n      <p style=\"color:#9A9B99;font-size:12px;margin:0 0 6px;text-transform:uppercase;letter-spacing:0.08em;\">Message</p>\n      <p style=\"color:#F0F0EE;margin:0;font-size:14px;line-height:1.7;\">{{ $json.message }}</p>\n    </div>\n    <div style=\"margin-top:20px;\">\n      <a href=\"mailto:{{ $json.email }}?subject=Re: {{ $json.interest }}\" style=\"display:inline-block;background:#00E5A0;color:#0B0C0E;padding:10px 20px;border-radius:6px;font-size:14px;font-weight:600;text-decoration:none;\">Reply to {{ $json.name }} ↗</a>\n    </div>\n  </div>\n  <p style=\"color:#5C5D5B;font-size:11px;text-align:center;margin-top:12px;\">Generated by Shinar Automation · Lead Gen Agent</p>\n</div>",
        "options": {}
      },
      "id": "node-notify-me",
      "name": "Notify Muhammed (Gmail)",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
